<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for Topaz Labs image and video enhancement APIs (upscale, denoise, sharpen, frame interpolation) based on the official OpenAPI specification.</Description>
    <PackageTags>topaz;topaz-labs;gigapixel;video-enhancement;image-upscaling;upscale;denoise;api;client;sdk;dotnet;openapi;specification;generated</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.4.1" />
  </ItemGroup>

</Project>
